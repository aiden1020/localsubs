{
  "manifest_version": 3,
  "name": "LocalSubs",
  "version": "0.2.0",
  "description": "Real-time, fully local AI subtitle translation for streaming video.",
  "key": "",
  "permissions": ["storage", "nativeMessaging"],
  "options_page": "options.html",
  "action": {
    "default_title": "LocalSubs Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.max.com/*",
    "*://*.hbomax.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.max.com/*",
        "*://*.hbomax.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
